{
  "expo": {
    "name": "Selah",
    "slug": "selah",
    "owner": "josiahturnq",
    "version": "1.0.0",
    "description": "A simple Bible app: read, plan, pray, and memorize.",
    "primaryColor": "#1B1B1D",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "selah",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.josiahturnq.selah",
      "supportsTablet": false,
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.josiahturnq.selah",
      "adaptiveIcon": {
        "backgroundColor": "#1B1B1D",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B1B1D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 170
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
